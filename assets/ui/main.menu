		style		WINDOW_STYLE_SHADER
		background	"ui/assets/logo_sd_dark"
		forecolor	1 1 1 1
		visible		1
		decoration
	}*/

	itemDef {
		name		"sd_logo"
		rect		4 394 54 54		// 16, 16 offset!!
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/logo_sd_dark"
		forecolor	1 1 1 1
		visible		1
		decoration
	}

	itemDef {
		name		"atvi_logo"
		rect		$evalfloat(640-(2*WINDOW_X)-48-4-108) 421 108 27		// 16, 16 offset!! (note offset to left a little as well)
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/logo_atvi_dark"
		forecolor	1 1 1 1
		visible		1
		decoration
	}

	itemDef {
		name		"id_logo"
		rect		$evalfloat(640-(2*WINDOW_X)-48) 400 48 48		// 16, 16 offset!!
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/logo_id_dark"
		forecolor	1 1 1 1
		visible		1
		decoration
	}


// Window //

  SUBWINDOWBIG( 0, 0, MENU_WIDTH, MENU_HEIGHT, "MAIN", 50 )

// Buttons //
#ifdef ETLEGACY
	BUTTON( 6, 32, MENU_WIDTH-12, 18, "PLAY ONLINE", .3, 14, close main ; /*close backgroundmusic ; open backgroundmusic_server ;*/ uiScript UpdateFilter ; uiScript ServerSortDown 4 ; open playonline )
#else
	BUTTON( 6, 32, MENU_WIDTH-12, 18, "PLAY ONLINE", .3, 14, close main ; open playonline )
#endif
	BUTTON( 6, 56, MENU_WIDTH-12, 18, "HOST GAME", .3, 14, close main ; /*close backgroundmusic ; open backgroundmusic_server ;*/ uiScript loadArenas ; uiScript initHostGameFeatures ; open hostgame )
	BUTTON( 6, 80, MENU_WIDTH-12, 18, "REPLAYS", .3, 14, close main ; open viewreplay )
	BUTTON( 6, 104, MENU_WIDTH-12, 18, "OPTIONS", .3, 14, close main ; open options )
	BUTTON( 6, 128, MENU_WIDTH-12, 18, "ETJUMP", .3, 14, close main ; open etjump )
	BUTTON( 6, 152, MENU_WIDTH-12, 18, "PROFILE", .3, 14, close main ; open profile )
	BUTTON( 6, 176, MENU_WIDTH-12, 18, "CREDITS", .3, 14, close main ; open credits_splashdamage )
	BUTTON( 6, 200, MENU_WIDTH-12, 18, "MODS", .3, 14, close main ; open mods )
	BUTTON( 6, 224, MENU_WIDTH-12, 18, "EXIT GAME", .3, 14, clearFocus ; open quit )

#ifdef DRAW_QUICK_CONNECT
	SUBWINDOW( QUICK_CONNECT_X, 0, QUICK_CONNECT_W, QUICK_CONNECT_H, "QUICK CONNECT" )

  itemDef {
    name            "quickConnect_window"
    group           GROUP_NAME
    rect            $evalint(QUICK_CONNECT_RECT_X) $evalint(QUICK_CONNECT_RECT_Y)
                    $evalint(QUICK_CONNECT_RECT_W) $evalint(QUICK_CONNECT_RECT_H)
    style           WINDOW_STYLE_EMPTY
    border          WINDOW_BORDER_FULL
    bordercolor     .1 .1 .1 .5
    visible         1
    decoration
  }

  NAMEDLABEL( "lblQuickConnectNoServers", QUICK_CONNECT_LABEL_POS(1), "No servers added", .18, ITEM_ALIGN_LEFT, 0, 7 )

  NAMEDLABEL( "lblQuickConnectServer1", QUICK_CONNECT_LABEL_POS(1), "", .18, ITEM_ALIGN_LEFT, 0, 7 )
  NAMEDBUTTON( "btnQuickConnectServer1Join", QUICK_CONNECT_BTN_JOIN_POS(1), "JOIN", .18, 9, JOIN_SERVER(1) )
  NAMEDBUTTON( "btnQuickConnectServer1Info", QUICK_CONNECT_BTN_INFO_POS(1), "INFO", .18, 9, SERVER_INFO(1) )
  NAMEDBUTTON( "btnQuickConnectServer1Edit", QUICK_CONNECT_BTN_EDIT_POS(1), "EDIT", .18, 9, EDIT_SERVER(1) )
  NAMEDBUTTON( "btnQuickConnectServer1Delete", QUICK_CONNECT_BTN_DELETE_POS(1), "DELETE", .18, 9, DELETE_SERVER(1) )

  NAMEDLABEL( "lblQuickConnectServer2", QUICK_CONNECT_LABEL_POS(2), "", .18, ITEM_ALIGN_LEFT, 0, 7 )
  NAMEDBUTTON( "btnQuickConnectServer2Join", QUICK_CONNECT_BTN_JOIN_POS(2), "JOIN", .18, 9, JOIN_SERVER(2) )
  NAMEDBUTTON( "btnQuickConnectServer2Info", QUICK_CONNECT_BTN_INFO_POS(2), "INFO", .18, 9, SERVER_INFO(2) )
  NAMEDBUTTON( "btnQuickConnectServer2Edit", QUICK_CONNECT_BTN_EDIT_POS(2), "EDIT", .18, 9, EDIT_SERVER(2) )
  NAMEDBUTTON( "btnQuickConnectServer2Delete", QUICK_CONNECT_BTN_DELETE_POS(2), "DELETE", .18, 9, DELETE_SERVER(2) )

  NAMEDLABEL( "lblQuickConnectServer3", QUICK_CONNECT_LABEL_POS(3), "", .18, ITEM_ALIGN_LEFT, 0, 7 )
  NAMEDBUTTON( "btnQuickConnectServer3Join", QUICK_CONNECT_BTN_JOIN_POS(3), "JOIN", .18, 9, JOIN_SERVER(3) )
  NAMEDBUTTON( "btnQuickConnectServer3Info", QUICK_CONNECT_BTN_INFO_POS(3), "INFO", .18, 9, SERVER_INFO(3) )
  NAMEDBUTTON( "btnQuickConnectServer3Edit", QUICK_CONNECT_BTN_EDIT_POS(3), "EDIT", .18, 9, EDIT_SERVER(3) )
  NAMEDBUTTON( "btnQuickConnectServer3Delete", QUICK_CONNECT_BTN_DELETE_POS(3), "DELETE", .18, 9, DELETE_SERVER(3) )

  NAMEDLABEL( "lblQuickConnectServer4", QUICK_CONNECT_LABEL_POS(4), "", .18, ITEM_ALIGN_LEFT, 0, 7 )
  NAMEDBUTTON( "btnQuickConnectServer4Join", QUICK_CONNECT_BTN_JOIN_POS(4), "JOIN", .18, 9, JOIN_SERVER(4) )
  NAMEDBUTTON( "btnQuickConnectServer4Info", QUICK_CONNECT_BTN_INFO_POS(4), "INFO", .18, 9, SERVER_INFO(4) )
  NAMEDBUTTON( "btnQuickConnectServer4Edit", QUICK_CONNECT_BTN_EDIT_POS(4), "EDIT", .18, 9, EDIT_SERVER(4) )
  NAMEDBUTTON( "btnQuickConnectServer4Delete", QUICK_CONNECT_BTN_DELETE_POS(4), "DELETE", .18, 9, DELETE_SERVER(4) )

  NAMEDLABEL( "lblQuickConnectServer5", QUICK_CONNECT_LABEL_POS(5), "", .18, ITEM_ALIGN_LEFT, 0, 7 )
  NAMEDBUTTON( "btnQuickConnectServer5Join", QUICK_CONNECT_BTN_JOIN_POS(5), "JOIN", .18, 9, JOIN_SERVER(5) )
  NAMEDBUTTON( "btnQuickConnectServer5Info", QUICK_CONNECT_BTN_INFO_POS(5), "INFO", .18, 9, SERVER_INFO(5) )
