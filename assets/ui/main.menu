// Defines //

#define WINDOW_X		16
#define WINDOW_Y		16
#define WINDOW_WIDTH	WINDOW_WIDTH_WIDE
#define WINDOW_HEIGHT	480
#define MENU_WIDTH	128
#define MENU_HEIGHT	248

#define MENU_NAME "main"
#define GROUP_NAME		"grpMain"

#define SETUP_SERVERSTATUS uiScript serverActionStatusType SERVERSTATUS_QUICKCONNECT ; setcvar ui_serverBrowser 0
#define JOIN_SERVER(x) uiScript serverActionJoinType JOINSERVER_QUICKCONNECT ; uiScript JoinServer x
#define SERVER_INFO(x) clearFocus ; uiScript uiPreviousMenu MENU_NAME ; SETUP_SERVERSTATUS ; uiScript ServerStatus x ; open popup_serverinfo
#define EDIT_SERVER(x) uiScript quickConnectSetEditData x ; open etjump_quickconnect_popup_edit
#define DELETE_SERVER(x) uiScript quickConnectSetEditData x ; open etjump_quickconnect_popup_delete

// Macros //

#include "ui/menudef.h"

#include "ui/menumacros.h"
#include "ui/menumacros_ext.h"

#include "ui/menudef_quickconnect.h"

// Opener //

menuDef {
	name		"main_opener"
	visible		0
	fullscreen	0
	rect		WINDOW_X WINDOW_Y MENU_WIDTH MENU_HEIGHT

	onOpen {
		open fadebox_black ;
		open background_1 ;
		setmenuitemcolor fadebox_black fadebox backcolor 0 0 0 1 ;
		fadeoutmenu fadebox_black ;
		open MENU_NAME ;
		clearcvar ui_profile_create_error ;
		close main_opener
	}
}

// Main Menu //

menuDef {
	name		MENU_NAME
	visible		0
	fullscreen	0
	rect		WINDOW_X WINDOW_Y WINDOW_WIDTH WINDOW_HEIGHT
	style		WINDOW_STYLE_FILLED

	onOpen {
		conditionalscript cl_profile 1
			( "clearFocus" )
			( "close main ; open profile_create_initial_opener" )	// do we want an abort here?

		// ydnar
		conditionalscript ROldModeCheck 2
			( "clearFocus ; open vid_confirm" )
			( "clearFocus" )

		conditionalscript cl_autoupdate 1
			( "checkautoupdate" )
			( "clearFocus" )

#ifdef DRAW_QUICK_CONNECT
    // hides/shows quick connect buttons based off the saved data
    uiScript setupQuickConnectMenuButtons
#endif
	}

	onEsc {
		clearFocus ;
		open quit
	}

// Background Logo //

	itemDef {
		name		"et_logo"
		rect		104 124 400 200		// 16, 16 offset!!
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/et_logo_huge"
		visible		1
		decoration
	}

// Company Logos //

	/*itemDef {
		name		"id_logo"
		rect		0 400 48 48		// 16, 16 offset!!
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/logo_id_dark"
		forecolor	1 1 1 1
		visible		1
		decoration
	}

	itemDef {
		name		"atvi_logo"
		rect		52 421 108 27		// 16, 16 offset!! (note offset to left a little as well)
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/logo_atvi_dark"
		forecolor	1 1 1 1
		visible		1
		decoration
	}

	itemDef {
		name		"sd_logo"
